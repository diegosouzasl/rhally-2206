# ── Portal do Cliente (backend) — variáveis de ambiente (EXEMPLO) ─────────────
# Copie para .env e preencha. NUNCA versione o .env real.

# App
HOST=0.0.0.0
PORT=3337

# Banco (MySQL) — banco PRÓPRIO do portal (separado do Rhally)
DATABASE_URL="mysql://portal_user:portal2025@127.0.0.1:3306/portal_cliente"

# Auth do portal (usuários do portal logam aqui)
PORTAL_JWT_SECRET=
PORTAL_JWT_EXPIRES_IN=8h

# Integração com o Rhally
# JWT_PASS DEVE ser o MESMO segredo do rhally-backend (usado p/ SSO e token de serviço)
RHALLY_JWT_PASS=
RHALLY_API_URL=http://localhost:4000

# CORS — origens permitidas (frontend do portal e/ou Rhally), separadas por vírgula
CORS_ORIGINS=http://localhost:5174,http://localhost:5173

# Asaas (faturamento) — use o sandbox em dev
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
# Token simples para validar a origem do webhook do Asaas (defina o mesmo no painel Asaas)
ASAAS_WEBHOOK_TOKEN=
